# MySQL 8 单机演示环境；复制为 .env 后必须替换 DB_PASSWORD
SERVER_PORT=8080
TCP_ENABLED=true
TCP_PORT=9100
SPRINKLER_MINIMUM_INTERVAL_SECONDS=300
SPRINKLER_DISPATCH_TIMEOUT_SECONDS=120
SPRINKLER_TIMEOUT_SCAN_MS=30000
SPRINKLER_TIMEOUT_SCAN_ENABLED=true
TOKEN_TTL_MINUTES=480
DEMO_DATA_ENABLED=false
DEVICE_OFFLINE_MONITOR_ENABLED=true
DEVICE_OFFLINE_TIMEOUT_SECONDS=300
DEVICE_OFFLINE_SCAN_INTERVAL_MS=30000
DEVICE_OFFLINE_INITIAL_DELAY_MS=60000
DEVICE_OFFLINE_BATCH_SIZE=200
AI_AGENT_MODE=DISABLED
AI_AGENT_MODEL=gpt-4.1-mini
# 启用 OPENAI_COMPATIBLE 时由后端读取；base URL 必须同时出现在白名单中。
AI_AGENT_BASE_URL=https://api.openai.com/v1
AI_AGENT_API_KEY=REPLACE_WITH_SERVER_SIDE_KEY
AI_AGENT_ALLOWED_BASE_URLS=https://api.openai.com/v1
AI_AGENT_USER_CONFIG_ENABLED=true
# 例如由密钥管理系统注入 `openssl rand -base64 32` 的结果；严禁提交真实值。
AI_AGENT_CREDENTIAL_ENCRYPTION_KEY=
AI_AGENT_APPROVED_MODELS=
AI_AGENT_CONNECT_TIMEOUT_MS=5000
AI_AGENT_READ_TIMEOUT_MS=60000
AI_AGENT_MAX_CONTENT_CHARS=8000
AI_AGENT_MAX_RESPONSE_CHARS=16000
AI_AGENT_MAX_HISTORY_MESSAGES=20
AI_AGENT_CONVERSATION_LOCK_STRIPES=256
AI_AGENT_CONVERSATION_LOCK_WAIT_MS=5000
AI_AGENT_MAX_CONCURRENT_REQUESTS=8
AI_AGENT_PER_USER_REQUESTS_PER_MINUTE=20
AI_AGENT_BULKHEAD_WAIT_MS=100
PUSH_WEBHOOK_ENABLED=false
PUSH_ALLOWED_ENDPOINTS=
PUSH_ALLOW_HTTP_LOOPBACK=false
PUSH_CONNECT_TIMEOUT_MS=3000
PUSH_REQUEST_TIMEOUT_MS=10000
VIDEO_ALLOWED_HOSTS=127.0.0.1,localhost
VIDEO_CONNECT_TIMEOUT_MS=3000
VISION_AI_ENABLED=false
VISION_AI_BASE_URL=http://127.0.0.1:5001
VISION_AI_ALLOWED_BASE_URLS=http://127.0.0.1:5001
VISION_AI_ALLOW_HTTP_LOOPBACK=true
VISION_AI_API_KEY=
VISION_AI_CONNECT_TIMEOUT_MS=3000
VISION_AI_REQUEST_TIMEOUT_MS=30000
SPRINKLER_GATEWAY_MODE=DISABLED
SPRINKLER_GATEWAY_BASE_URL=
SPRINKLER_GATEWAY_ALLOWED_BASE_URLS=
SPRINKLER_GATEWAY_ALLOW_HTTP_LOOPBACK=false
SPRINKLER_GATEWAY_API_KEY=
SPRINKLER_GATEWAY_CALLBACK_TOKEN=
SPRINKLER_GATEWAY_CONNECT_TIMEOUT_MS=3000
SPRINKLER_GATEWAY_REQUEST_TIMEOUT_MS=10000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

SPRING_PROFILES_ACTIVE=mysql
DB_URL=jdbc:mysql://127.0.0.1:3306/db_sitesafe?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=false&useSSL=false
DB_USERNAME=sitesafe_app
DB_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD

FRONTEND_PORT=5173
VITE_API_BASE=/api
VITE_WS_BASE=

SIMULATOR_WEB_PORT=9200
TCP_HOST=127.0.0.1

AI_PORT=5001
AI_DEMO_MODE=false
AI_ENABLE_MODEL=false
